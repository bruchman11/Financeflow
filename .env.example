# Supabase — public (expostas no client)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...

# Supabase — server-only (NUNCA expor ao client)
# Usar apenas para tarefas administrativas/seed e pela API de integração.
SUPABASE_SERVICE_ROLE_KEY=ey...

# Integração n8n / WhatsApp (server-only) ──────────────────────────────────────
# Chave da API de integração: o n8n envia no header `x-api-key`.
# Gere uma forte, ex.: `openssl rand -hex 32`.
INTEGRATION_API_KEY=troque-por-uma-chave-forte

# Allowlist telefone→empresa (JSON). Só números aqui podem lançar/consultar.
# phone em dígitos (E.164 sem "+"); companyId e userId do Supabase.
# Ex.: [{"phone":"5567999999999","companyId":"uuid-empresa","userId":"uuid-do-profile"}]
INTEGRATION_CONTACTS=[]
